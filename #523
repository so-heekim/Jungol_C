#include <stdio.h>

int main()
{
    int a,b;
    scanf("%d %d",&a,&b);

    if(a>b){
        printf("%d > %d --- 1\n",a,b);
    }else{
        printf("%d > %d --- 0\n",a,b);
    }

    if(a<b){
        printf("%d < %d --- 1\n",a,b);
    }else{
        printf("%d < %d --- 0\n",a,b);
    }

    if(a>=b){
        printf("%d >= %d --- 1\n",a,b);
    }else{
        printf("%d >= %d --- 0\n",a,b);
    }

    if(a<=b){
        printf("%d <= %d --- 1\n",a,b);
    }else{
        printf("%d <= %d --- 0\n",a,b);
    }
}
